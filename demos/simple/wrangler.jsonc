{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "emdash-test",
	"compatibility_date": "2026-03-01",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "emdash_test",
			"database_id": "61164be7-0e4c-435c-8906-c3c0089450fa",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			// R2 bucket names do not support "_", use hyphenated equivalent.
			"bucket_name": "emdash-test-media",
		},
	],
}
